# -----------------------------------------------------------------------------
# Aplicación (Laravel + Inertia)
# -----------------------------------------------------------------------------
APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Misma URL pública que APP_URL si los assets se sirven desde el mismo host (u otro origen vía CDN)
ASSET_URL=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# -----------------------------------------------------------------------------
# Registro de logs
# -----------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Base de datos (tests usan sqlite en memoria vía phpunit.xml)
# Desarrollo local rápido: sqlite. Producción CFRD: pgsql.
# -----------------------------------------------------------------------------
DB_CONNECTION=sqlite
# DB_DATABASE=/ruta/absoluta/database.sqlite
# --- PostgreSQL (p. ej. stack CFRD) ---
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# -----------------------------------------------------------------------------
# Sesión, caché y colas (en CFRD suele usarse redis para los tres)
# -----------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120

CACHE_STORE=database
QUEUE_CONNECTION=database

# -----------------------------------------------------------------------------
# Redis (necesario si SESSION_DRIVER, CACHE_STORE o QUEUE_CONNECTION = redis)
# -----------------------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_USERNAME=
REDIS_PASSWORD=null
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Correo (Fortify: recuperación / verificación; en local suele bastar "log")
# -----------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# Almacenamiento (contenido local / H5P; sin S3 en el flujo por defecto)
# -----------------------------------------------------------------------------
FILESYSTEM_DISK=local

# -----------------------------------------------------------------------------
# Vite (frontend)
# -----------------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
# En producción con assets compilados, vacío
VITE_DEV_SERVER_URL=

# -----------------------------------------------------------------------------
# LTI 1.3 — herramienta (este servicio) y claves JWKS
# Valores por defecto de rutas: cfrd-lti/config/cfrd-lti.php
# -----------------------------------------------------------------------------
LTI_TOOL_ISSUER=
LTI_TOOL_CLIENT_ID=
LTI_TOOL_KID=cfrd-lti-1
# Opcional si no usas storage/app/lti/tool_*.pem
# LTI_TOOL_PRIVATE_KEY_PATH=
# LTI_TOOL_PUBLIC_KEY_PATH=

# URIs extra permitidas para target_link_uri (coma-separadas); siempre se incluyen APP_URL/ y APP_URL/lti/launch
LTI_OIDC_ALLOWED_TARGET_URIS=

# -----------------------------------------------------------------------------
# LTI — plataforma LMS (issuer del id_token entrante; JWKS y OIDC de la plataforma)
# En muchos entornos solo aplica al validar contra un LMS concreto; puede dejarse vacío si usas solo DB de plataformas.
# -----------------------------------------------------------------------------
LTI_PLATFORM_ISSUER=
LTI_PLATFORM_CLIENT_ID=
LTI_PLATFORM_JWKS_JSON='{"keys":[]}'
LTI_PLATFORM_TOKEN_ENDPOINT=
LTI_PLATFORM_AUTHORIZATION_ENDPOINT=
