{
    "name": "cfrd/lti",
    "description": "LTI 1.3 Core y Deep Linking 2.0 (CFRD, sin dependencia de terceros)",
    "type": "library",
    "license": "MIT",
    "version": "0.1.0",
    "require": {
        "php": "^8.3",
        "firebase/php-jwt": "^6.10",
        "illuminate/contracts": "^12.0|^13.0",
        "illuminate/http": "^12.0|^13.0",
        "illuminate/routing": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "Cfrd\\Lti\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Cfrd\\Lti\\CfrdLtiServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
