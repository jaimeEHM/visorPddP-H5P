# Fragmento para fusionar en .env cuando uses deploy/cfrd-stack/docker-compose.yml
# con el stack Microservicios (Postgres, Redis, Traefik).

# Host público del servicio detrás de Traefik
APP_URL=https://pddp.cfrd.cl
ASSET_URL=https://pddp.cfrd.cl

# No pongas PDDP_TRAEFIK_RULE=Host(`...`) en .env de Laravel: las comillas
# invertidas rompen el parser y dejan APP_KEY vacío. La regla Traefik va en
# docker-compose.yml (labels) o en variables de entorno al ejecutar docker compose.

# Red Docker del stack CFRD (si no es la por defecto)
# CFRD_STACK_NETWORK=microservicios_service_net

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=pddp_db
# Alinear con POSTGRES_USER / POSTGRES_PASSWORD del .env de Microservicios
DB_USERNAME=cfrd_admin
DB_PASSWORD=

CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_CLIENT=phpredis
REDIS_USERNAME=
REDIS_PASSWORD=

# Producción con assets compilados en el contenedor
VITE_DEV_SERVER_URL=
